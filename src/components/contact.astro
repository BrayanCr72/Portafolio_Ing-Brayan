---
interface Props {
  lang?: 'es' | 'en';
}

const { lang = 'es' } = Astro.props;

const content = {
  es: {
    title: 'Contacto',
    subtitle: '¿Tienes un proyecto en mente?',
    description: 'Me encantaría saber de ti. Ya sea que representes una empresa o seas un cliente independiente, estoy aquí para ayudarte a hacer realidad tus ideas.',
    form: {
      name: 'Nombre completo',
      namePlaceholder: 'Juan Pérez',
      email: 'Correo electrónico',
      emailPlaceholder: 'tu@email.com',
      type: 'Tipo de contacto',
      typeCompany: 'Empresa',
      typeFreelance: 'Freelance / Proyecto personal',
      company: 'Nombre de la empresa',
      companyPlaceholder: 'Nombre de tu empresa (opcional)',
      message: 'Cuéntame sobre tu proyecto',
      messagePlaceholder: 'Describe tu proyecto, necesidades o cualquier pregunta que tengas...',
      submit: 'Enviar mensaje',
      sending: 'Enviando...',
      success: '¡Mensaje enviado! Me pondré en contacto pronto.',
      error: 'Hubo un error. Por favor intenta de nuevo.'
    },
    contact: {
      title: 'Otras formas de contacto',
      email: 'Email',
      phone: 'Teléfono',
      location: 'Ubicación'
    }
  },
  en: {
    title: 'Contact',
    subtitle: 'Have a project in mind?',
    description: "I'd love to hear from you. Whether you represent a company or you're an independent client, I'm here to help bring your ideas to life.",
    form: {
      name: 'Full name',
      namePlaceholder: 'John Doe',
      email: 'Email address',
      emailPlaceholder: 'your@email.com',
      type: 'Contact type',
      typeCompany: 'Company',
      typeFreelance: 'Freelance / Personal project',
      company: 'Company name',
      companyPlaceholder: 'Your company name (optional)',
      message: 'Tell me about your project',
      messagePlaceholder: 'Describe your project, needs, or any questions you have...',
      submit: 'Send message',
      sending: 'Sending...',
      success: 'Message sent! I will get in touch soon.',
      error: 'There was an error. Please try again.'
    },
    contact: {
      title: 'Other ways to reach me',
      email: 'Email',
      phone: 'Phone',
      location: 'Location'
    }
  }
};

const text = content[lang];
---

<section 
  id="contact" 
  data-gsap="contact-section"
  class="min-h-screen bg-gradient-to-b from-slate-800 to-slate-900 py-20 px-6"
>
  <div class="container mx-auto max-w-6xl">
    <!-- Section Header -->
    <div 
      id="contact-header" 
      data-gsap="contact-header"
      class="text-center mb-16"
    >
      <h2 class="text-4xl md:text-5xl font-bold text-white mb-4">
        <span class="bg-clip-text text-transparent bg-gradient-to-r from-purple-400 via-pink-400 to-yellow-400">
          {text.title}
        </span>
      </h2>
      <div class="w-24 h-1 bg-gradient-to-r from-purple-400 to-pink-400 mx-auto rounded-full mb-6"></div>
      
      <h3 class="text-2xl md:text-3xl font-semibold text-purple-200 mb-4">
        {text.subtitle}
      </h3>
      <p class="text-gray-400 text-lg max-w-2xl mx-auto">
        {text.description}
      </p>
    </div>

    <div class="grid lg:grid-cols-3 gap-8">
      <!-- Contact Form -->
      <div 
        id="contact-form-container" 
        data-gsap="contact-form"
        class="lg:col-span-2 bg-slate-800/50 backdrop-blur-sm rounded-2xl p-8 border border-white/10"
      >
        <form id="contact-form" class="space-y-6">
          <!-- Name -->
          <div id="form-name-group" data-gsap="form-name">
            <label for="name" class="block text-sm font-semibold text-gray-300 mb-2">
              {text.form.name} <span class="text-red-400">*</span>
            </label>
            <input
              type="text"
              id="name"
              name="name"
              required
              placeholder={text.form.namePlaceholder}
              class="w-full px-4 py-3 bg-slate-900/50 border border-white/10 rounded-lg text-white placeholder-gray-500 focus:outline-none focus:border-purple-400 transition-colors"
            />
          </div>

          <!-- Email -->
          <div id="form-email-group" data-gsap="form-email">
            <label for="email" class="block text-sm font-semibold text-gray-300 mb-2">
              {text.form.email} <span class="text-red-400">*</span>
            </label>
            <input
              type="email"
              id="email"
              name="email"
              required
              placeholder={text.form.emailPlaceholder}
              class="w-full px-4 py-3 bg-slate-900/50 border border-white/10 rounded-lg text-white placeholder-gray-500 focus:outline-none focus:border-purple-400 transition-colors"
            />
          </div>

          <!-- Contact Type -->
          <div id="form-type-group" data-gsap="form-type">
            <label for="contact-type" class="block text-sm font-semibold text-gray-300 mb-2">
              {text.form.type} <span class="text-red-400">*</span>
            </label>
            <select
              id="contact-type"
              name="contact-type"
              required
              class="w-full px-4 py-3 bg-slate-900/50 border border-white/10 rounded-lg text-white focus:outline-none focus:border-purple-400 transition-colors"
            >
              <option value="">{lang === 'es' ? 'Selecciona una opción' : 'Select an option'}</option>
              <option value="company">{text.form.typeCompany}</option>
              <option value="freelance">{text.form.typeFreelance}</option>
            </select>
          </div>

          <!-- Company Fields (shown when "company" is selected) -->
          <div id="company-fields" class="hidden space-y-6">
            <!-- Company Name -->
            <div id="form-company-group" data-gsap="form-company">
              <label for="company" class="block text-sm font-semibold text-gray-300 mb-2">
                {text.form.company} <span class="text-red-400">*</span>
              </label>
              <input
                type="text"
                id="company"
                name="company"
                placeholder={text.form.companyPlaceholder}
                class="w-full px-4 py-3 bg-slate-900/50 border border-white/10 rounded-lg text-white placeholder-gray-500 focus:outline-none focus:border-purple-400 transition-colors"
              />
            </div>

            <!-- Position -->
            <div id="form-position-group" data-gsap="form-position">
              <label for="position" class="block text-sm font-semibold text-gray-300 mb-2">
                {lang === 'es' ? 'Tu cargo en la empresa' : 'Your position'}
              </label>
              <input
                type="text"
                id="position"
                name="position"
                placeholder={lang === 'es' ? 'ej: Gerente de TI, Reclutador, CEO...' : 'e.g: IT Manager, Recruiter, CEO...'}
                class="w-full px-4 py-3 bg-slate-900/50 border border-white/10 rounded-lg text-white placeholder-gray-500 focus:outline-none focus:border-purple-400 transition-colors"
              />
            </div>
          </div>

          <!-- Freelance Fields (shown when "freelance" is selected) -->
          <div id="freelance-fields" class="hidden space-y-6">
            <!-- Project Type -->
            <div id="form-project-type-group" data-gsap="form-project-type">
              <label for="project-type" class="block text-sm font-semibold text-gray-300 mb-2">
                {lang === 'es' ? 'Tipo de proyecto' : 'Project type'}
              </label>
              <input
                type="text"
                id="project-type"
                name="project-type"
                placeholder={lang === 'es' ? 'ej: Sitio web, App móvil, Sistema...' : 'e.g: Website, Mobile app, System...'}
                class="w-full px-4 py-3 bg-slate-900/50 border border-white/10 rounded-lg text-white placeholder-gray-500 focus:outline-none focus:border-purple-400 transition-colors"
              />
            </div>

            <!-- Budget Range (Optional) -->
            <!-- <div id="form-budget-group" data-gsap="form-budget">
              <label for="budget" class="block text-sm font-semibold text-gray-300 mb-2">
                {lang === 'es' ? 'Presupuesto estimado (opcional)' : 'Estimated budget (optional)'}
              </label>
              <select
                id="budget"
                name="budget"
                class="w-full px-4 py-3 bg-slate-900/50 border border-white/10 rounded-lg text-white focus:outline-none focus:border-purple-400 transition-colors"
              >
                <option value="">{lang === 'es' ? 'Selecciona un rango' : 'Select a range'}</option>
                <option value="<1000">{lang === 'es' ? 'Menos de $1,000' : 'Less than $1,000'}</option>
                <option value="1000-3000">$1,000 - $3,000</option>
                <option value="3000-5000">$3,000 - $5,000</option>
                <option value="5000-10000">$5,000 - $10,000</option>
                <option value=">10000">{lang === 'es' ? 'Más de $10,000' : 'More than $10,000'}</option>
              </select>
            </div> -->
          </div>

          <!-- Message -->
          <div id="form-message-group" data-gsap="form-message">
            <label for="message" class="block text-sm font-semibold text-gray-300 mb-2">
              {text.form.message} <span class="text-red-400">*</span>
            </label>
            <textarea
              id="message"
              name="message"
              required
              rows="6"
              placeholder={text.form.messagePlaceholder}
              class="w-full px-4 py-3 bg-slate-900/50 border border-white/10 rounded-lg text-white placeholder-gray-500 focus:outline-none focus:border-purple-400 transition-colors resize-none"
            ></textarea>
          </div>

          <!-- Submit Button -->
          <button
            type="submit"
            id="submit-button"
            data-gsap="form-submit"
            class="w-full bg-gradient-to-r from-purple-500 via-pink-500 to-yellow-500 text-white font-bold py-4 px-8 rounded-full text-lg shadow-lg hover:shadow-2xl transform hover:scale-105 transition-all duration-300"
          >
            {text.form.submit}
          </button>

          <!-- Status Message -->
          <div id="form-status" class="hidden text-center p-4 rounded-lg"></div>
        </form>
      </div>

      <!-- Contact Info -->
      <div 
        id="contact-info" 
        data-gsap="contact-info"
        class="space-y-6"
      >
        <div class="bg-slate-800/50 backdrop-blur-sm rounded-2xl p-6 border border-white/10">
          <h4 class="text-xl font-bold text-white mb-6">{text.contact.title}</h4>
          
          <div class="space-y-4">
            <!-- Email -->
            <div class="flex items-start gap-4">
              <div class="w-12 h-12 bg-purple-500/20 rounded-lg flex items-center justify-center flex-shrink-0">
                <svg class="w-6 h-6 text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                </svg>
              </div>
              <div>
                <p class="text-sm text-gray-400 mb-1">{text.contact.email}</p>
                <a href="mailto:ordonezbrayan62@gmail.com" class="text-white hover:text-purple-400 transition-colors">
                  ordonezbrayan62@gmail.com
                </a>
              </div>
            </div>

            <!-- Phone -->
            <div class="flex items-start gap-4">
              <div class="w-12 h-12 bg-pink-500/20 rounded-lg flex items-center justify-center flex-shrink-0">
                <svg class="w-6 h-6 text-pink-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
                </svg>
              </div>
              <div>
                <p class="text-sm text-gray-400 mb-1">{text.contact.phone}</p>
                <a href="tel:+50612345678" class="text-white hover:text-pink-400 transition-colors">
                  +506 62235826
                </a>
              </div>
            </div>

            <!-- Location -->
            <div class="flex items-start gap-4">
              <div class="w-12 h-12 bg-yellow-500/20 rounded-lg flex items-center justify-center flex-shrink-0">
                <svg class="w-6 h-6 text-yellow-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                </svg>
              </div>
              <div>
                <p class="text-sm text-gray-400 mb-1">{text.contact.location}</p>
                <p class="text-white">Costa Rica</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Social Links -->
        <div class="bg-slate-800/50 backdrop-blur-sm rounded-2xl p-6 border border-white/10">
          <h4 class="text-xl font-bold text-white mb-4">Social</h4>
          <div class="flex gap-4">
            <a 
              href="https://github.com/tuusuario" 
              target="_blank"
              rel="noopener noreferrer"
              class="w-12 h-12 bg-white/10 hover:bg-white/20 rounded-lg flex items-center justify-center transition-all duration-300 hover:scale-110"
              aria-label="GitHub"
            >
              <svg class="w-6 h-6 text-white" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
              </svg>
            </a>
            <a 
              href="https://linkedin.com/in/tuusuario" 
              target="_blank"
              rel="noopener noreferrer"
              class="w-12 h-12 bg-white/10 hover:bg-white/20 rounded-lg flex items-center justify-center transition-all duration-300 hover:scale-110"
              aria-label="LinkedIn"
            >
              <svg class="w-6 h-6 text-white" fill="currentColor" viewBox="0 0 24 24">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
              </svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const submitButton = document.getElementById('submit-button') as HTMLButtonElement;
  const statusDiv = document.getElementById('form-status') as HTMLDivElement;
  const contactTypeSelect = document.getElementById('contact-type') as HTMLSelectElement;
  const companyFields = document.getElementById('company-fields') as HTMLDivElement;
  const freelanceFields = document.getElementById('freelance-fields') as HTMLDivElement;
  const companyInput = document.getElementById('company') as HTMLInputElement;

  // Manejar cambio de tipo de contacto
  contactTypeSelect?.addEventListener('change', (e) => {
    const value = (e.target as HTMLSelectElement).value;
    
    // Ocultar todos los campos específicos
    companyFields?.classList.add('hidden');
    freelanceFields?.classList.add('hidden');
    
    // Remover required de todos los campos opcionales
    companyInput?.removeAttribute('required');
    
    // Mostrar campos según selección
    if (value === 'company') {
      companyFields?.classList.remove('hidden');
      companyInput?.setAttribute('required', 'required');
    } else if (value === 'freelance') {
      freelanceFields?.classList.remove('hidden');
    }
  });

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    
    // Cambiar estado del botón
    const originalText = submitButton.textContent;
    const lang = document.documentElement.lang;
    submitButton.disabled = true;
    submitButton.textContent = lang === 'es' ? 'Enviando...' : 'Sending...';
    
    // Obtener datos del formulario
    const formData = new FormData(form);
    const contactType = formData.get('contact-type');
    
    const data: any = {
      name: formData.get('name'),
      email: formData.get('email'),
      contactType: contactType,
      message: formData.get('message')
    };

    // Agregar campos específicos según el tipo
    if (contactType === 'company') {
      data.company = formData.get('company');
      data.position = formData.get('position');
    } else if (contactType === 'freelance') {
      data.projectType = formData.get('project-type');
      data.budget = formData.get('budget');
    }

    try {
      // Aquí puedes integrar con un servicio como FormSpree, EmailJS, o tu propio backend
      // Por ahora, simulamos el envío
      console.log('Form data:', data);
      await new Promise(resolve => setTimeout(resolve, 1500));
      
      // Mostrar mensaje de éxito
      statusDiv.classList.remove('hidden', 'bg-red-500/20', 'text-red-400');
      statusDiv.classList.add('bg-green-500/20', 'text-green-400');
      statusDiv.textContent = lang === 'es' 
        ? '¡Mensaje enviado! Me pondré en contacto pronto.' 
        : 'Message sent! I will get in touch soon.';
      
      // Limpiar formulario y ocultar campos específicos
      form.reset();
      companyFields?.classList.add('hidden');
      freelanceFields?.classList.add('hidden');
      
      // Ocultar mensaje después de 5 segundos
      setTimeout(() => {
        statusDiv.classList.add('hidden');
      }, 5000);
      
    } catch (error) {
      // Mostrar mensaje de error
      statusDiv.classList.remove('hidden', 'bg-green-500/20', 'text-green-400');
      statusDiv.classList.add('bg-red-500/20', 'text-red-400');
      statusDiv.textContent = lang === 'es'
        ? 'Hubo un error. Por favor intenta de nuevo.'
        : 'There was an error. Please try again.';
    } finally {
      // Restaurar botón
      submitButton.disabled = false;
      submitButton.textContent = originalText;
    }
  });
</script>