---
import { experience } from '../data/experinceData';

interface Props {
  lang?: 'es' | 'en';
}

const { lang = 'es' } = Astro.props;
const data = experience[lang];

// Organizar las empresas en orden
const companies = [
  { key: 'srs', data: data.srs, icon: 'https://d3ecg82tkkq2g3.cloudfront.net/Image/LOGOWEB.webp', color: 'blue' },
  { key: 'fundes', data: data.fundes, icon: '🏛️', color: 'white' },
  { key: 'universidad', data: data.universidad, icon: 'https://www.relacionespublicas.una.ac.cr/images/servicios/Logo-UNA-Rojo_FondoTransparente.png', color: 'red' },
  { key: 'freelance', data: data.freelance, icon: '💼', color: 'yellow' }
];

const colorClasses = {
  purple: {
    border: 'border-purple-500',
    bg: 'bg-purple-500/10',
    text: 'text-purple-400',
    gradient: 'from-purple-400 to-pink-400'
  },
  blue: {
    border: 'border-blue-500',
    bg: 'bg-blue-transparent',
    text: 'text-blue-400',
    gradient: 'from-blue-400 to-cyan-400'
  },
  white: {
    border: 'border-white',
    bg: 'bg-transparent',
    text: 'text-white',
    gradient: 'from-white to-gray-400'
  },
  red: {
    border: 'border-red-500',
    bg: 'bg-red-transparent',
    text: 'text-red-400',
    gradient: 'from-red-400 to-rose-400'
  },
  yellow: {
    border: 'border-yellow-500',
    bg: 'bg-transparent',
    text: 'text-yellow-400',
    gradient: 'from-yellow-400 to-orange-400'
  }
};
---

<section 
  id="experience" 
  data-gsap="experience-section"
  class="min-h-screen bg-gradient-to-b from-slate-900 to-slate-800 py-20 px-6"
>
  <div class="container mx-auto max-w-7xl">
    <!-- Section Header -->
    <div 
      id="experience-header" 
      data-gsap="experience-header"
      class="text-center mb-16"
    >
      <h2 class="text-4xl md:text-5xl font-bold text-white mb-4">
        <span class="bg-clip-text text-transparent bg-gradient-to-r from-purple-400 via-pink-400 to-yellow-400">
          {data.title}
        </span>
      </h2>
      <div class="w-24 h-1 bg-gradient-to-r from-purple-400 to-pink-400 mx-auto rounded-full"></div>
    </div>

    <!-- Timeline Container -->
    <div id="experience-timeline" data-gsap="experience-timeline" class="space-y-16">
      {companies.map((company, companyIndex) => (
        <div 
          id={`company-${company.key}`}
          data-gsap={`company-${company.key}`}
          class="relative"
        >
          <!-- Company Header -->
          <div class="flex items-center gap-4 mb-8">
            <div class={`w-16 h-16 rounded-full ${colorClasses[company.color as keyof typeof colorClasses].bg} flex items-center justify-center border-2 ${colorClasses[company.color as keyof typeof colorClasses].border} overflow-hidden`}>
              {company.icon.startsWith('http') ? (
                <img 
                  src={company.icon} 
                  alt={company.data.title}
                  class="w-full h-full object-contain p-2"
                />
              ) : (
                <span class="text-3xl">{company.icon}</span>
              )}
            </div>
            <h3 class={`text-3xl font-bold ${colorClasses[company.color as keyof typeof colorClasses].text}`}>
              {company.data.title}
            </h3>
          </div>

          <!-- Projects Grid -->
          <div class="grid md:grid-cols-2 gap-6">
            {company.data.projects.map((project, projectIndex) => (
              <div
                id={`project-${company.key}-${projectIndex}`}
                data-gsap={`project-card-${companyIndex}-${projectIndex}`}
                class="bg-slate-800/50 backdrop-blur-sm rounded-xl p-6 border border-white/10 hover:border-purple-400/50 transition-all duration-300 hover:shadow-xl hover:shadow-purple-500/20 group"
              >
                <!-- Project Name -->
                <h4 class="text-xl font-bold text-white mb-3 group-hover:text-purple-400 transition-colors">
                  {project.name}
                </h4>

                <!-- Description -->
                <p class="text-gray-400 text-sm mb-4 leading-relaxed">
                  {project.description}
                </p>

                <!-- Technologies -->
                <div class="mb-4">
                  <h5 class="text-xs font-bold text-blue-400 uppercase mb-2">
                    {lang === 'es' ? 'Tecnologías' : 'Technologies'}
                  </h5>
                  <div class="flex flex-wrap gap-2">
                    {project.technologies.map((tech) => (
                      <span class="px-3 py-1 text-xs rounded-full bg-purple-500/20 text-purple-300 border border-purple-500/30">
                        {tech}
                      </span>
                    ))}
                  </div>
                </div>

                <!-- Role -->
                <div class="mb-4">
                  <h5 class="text-xs font-bold  text-purple-400 uppercase mb-1">
                    {lang === 'es' ? 'Mi rol' : 'My role'}
                  </h5>
                  <p class="text-gray-400 text-sm leading-relaxed">
                    {project.role}
                  </p>
                </div>

                <!-- Challenge -->
                <div class="mb-4">
                  <h5 class="text-xs font-bold text-yellow-400  uppercase mb-1">
                    {lang === 'es' ? 'Desafío' : 'Challenge'}
                  </h5>
                  <p class="text-gray-400 text-sm leading-relaxed">
                    {project.challenge}
                  </p>
                </div>

                <!-- Impact -->
                <div class="border-t border-white/10 pt-4">
                  <h5 class="text-xs font-bold text-green-400 uppercase mb-1">
                    {lang === 'es' ? ' Impacto' : ' Impact'}
                  </h5>
                  <p class="text-gray-400 text-sm leading-relaxed">
                    {project.impact}
                  </p>
                </div>
                {project.Url && (
                  <div class="mt-4">
                    <a href={project.Url} target="_blank" class="text-sm text-cyan-400 hover:underline">
                      {lang === 'es' ? 'Visitar sitio' : 'Visit site'}
                    </a>
                  </div>
                )}
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>

    <!-- CTA -->
    <div 
      id="experience-cta" 
      data-gsap="experience-cta"
      class="text-center mt-16"
    >
      <a 
        href="#contact"
        class="inline-block bg-gradient-to-r from-purple-500 via-pink-500 to-yellow-500 text-white font-bold py-4 px-8 rounded-full text-lg shadow-lg hover:shadow-2xl transform hover:scale-105 transition-all duration-300"
      >
        {lang === 'es' ? '¿Trabajamos juntos?' : "Let's work together"}
      </a>
    </div>
  </div>
</section>