---
import { aboutMeData } from '../data/aboutMeData';

interface Props {
  lang?: 'es' | 'en';
}

const { lang = 'en' } = Astro.props;
const data = aboutMeData[lang];
---

<section 
  id="about" 
  data-gsap="about-main-container"
  class="min-h-screen bg-gradient-to-b from-slate-900 to-slate-800 text-white py-20 relative overflow-hidden"
>
  <!-- Subtle background accent -->
  <div class="absolute top-0 right-0 w-96 h-96 bg-purple-600/10 rounded-full blur-3xl"></div>
  <div class="absolute bottom-0 left-0 w-96 h-96 bg-pink-600/10 rounded-full blur-3xl"></div>

  <div class="container mx-auto px-6 relative z-10">
    <!-- Section Title -->
    <div 
      id="about-header" 
      data-gsap="about-header"
      class="text-center mb-16"
    >
      <h2 
        id="about-title" 
        data-gsap="about-title-text"
        class="text-4xl md:text-5xl lg:text-6xl font-bold mb-4"
      >
        <span class="bg-clip-text text-transparent bg-gradient-to-r from-purple-400 to-pink-400">
          {data.title}
        </span>
      </h2>
      <div class="w-24 h-1 bg-gradient-to-r from-purple-400 to-pink-400 mx-auto rounded-full"></div>
    </div>

    <!-- Main Content -->
    <div class="max-w-5xl mx-auto space-y-12">
      <!-- Introduction -->
      <div 
        id="about-intro" 
        data-gsap="about-intro-block"
        class="relative"
      >
        <div class="absolute -left-4 top-0 w-1 h-full bg-gradient-to-b from-purple-400 to-transparent rounded-full"></div>
        <p 
          id="about-intro-text" 
          data-gsap="intro-paragraph"
          class="text-xl md:text-2xl text-gray-200 leading-relaxed pl-8"
        >
          {data.intro}
        </p>
      </div>

      <!-- Journey Section -->
      <div 
        id="about-journey" 
        data-gsap="journey-block"
        class="bg-white/5 backdrop-blur-sm rounded-2xl p-8 md:p-10 border border-white/10 hover:border-purple-400/30 transition-all duration-500"
      >
        <h3 
          id="journey-title" 
          data-gsap="journey-title"
          class="text-2xl md:text-3xl font-semibold mb-4 text-purple-300"
        >
          {data.sections.journey.title}
        </h3>
        <p 
          id="journey-content" 
          data-gsap="journey-paragraph"
          class="text-lg text-gray-300 leading-relaxed"
        >
          {data.sections.journey.content}
        </p>
      </div>

      <!-- Experience Section -->
      <div 
        id="about-experience" 
        data-gsap="experience-block"
        class="bg-white/5 backdrop-blur-sm rounded-2xl p-8 md:p-10 border border-white/10 hover:border-pink-400/30 transition-all duration-500"
      >
        <h3 
          id="experience-title" 
          data-gsap="experience-title"
          class="text-2xl md:text-3xl font-semibold mb-4 text-pink-300"
        >
          {data.sections.experience.title}
        </h3>
        <p 
          id="experience-content" 
          data-gsap="experience-paragraph"
          class="text-lg text-gray-300 leading-relaxed mb-4"
        >
          {data.sections.experience.content}
        </p>
        <p 
          id="experience-additional" 
          data-gsap="experience-additional"
          class="text-lg text-gray-300 leading-relaxed"
        >
          {data.sections.experience.additional}
        </p>
      </div>

      <!-- Two Column Section -->
      <div 
        id="about-two-column" 
        data-gsap="two-column-container"
        class="grid md:grid-cols-2 gap-8"
      >
        <!-- Work Style -->
        <div 
          id="about-workstyle" 
          data-gsap="workstyle-block"
          class="bg-white/5 backdrop-blur-sm rounded-2xl p-8 border border-white/10 hover:border-yellow-400/30 transition-all duration-500"
        >
          <h3 
            id="workstyle-title" 
            data-gsap="workstyle-title"
            class="text-xl md:text-2xl font-semibold mb-4 text-yellow-300"
          >
            {data.sections.workStyle.title}
          </h3>
          <p 
            id="workstyle-content" 
            data-gsap="workstyle-paragraph"
            class="text-base text-gray-300 leading-relaxed"
          >
            {data.sections.workStyle.content}
          </p>
        </div>

        <!-- Goals -->
        <div 
          id="about-goals" 
          data-gsap="goals-block"
          class="bg-white/5 backdrop-blur-sm rounded-2xl p-8 border border-white/10 hover:border-blue-400/30 transition-all duration-500"
        >
          <h3 
            id="goals-title" 
            data-gsap="goals-title"
            class="text-xl md:text-2xl font-semibold mb-4 text-blue-300"
          >
            {data.sections.goals.title}
          </h3>
          <p 
            id="goals-content" 
            data-gsap="goals-paragraph"
            class="text-base text-gray-300 leading-relaxed"
          >
            {data.sections.goals.content}
          </p>
        </div>
      </div>

      <!-- Personal Section -->
      <div 
        id="about-personal" 
        data-gsap="personal-block"
        class="relative overflow-hidden"
      >
        <div class="absolute inset-0 bg-gradient-to-r from-purple-500/10 via-pink-500/10 to-yellow-500/10 rounded-2xl"></div>
        <div class="relative bg-white/5 backdrop-blur-sm rounded-2xl p-8 md:p-10 border border-white/10">
          <h3 
            id="personal-title" 
            data-gsap="personal-title"
            class="text-2xl md:text-3xl font-semibold mb-4 bg-clip-text text-transparent bg-gradient-to-r from-purple-400 via-pink-400 to-yellow-400"
          >
            {data.sections.personal.title}
          </h3>
          <p 
            id="personal-content" 
            data-gsap="personal-paragraph"
            class="text-lg text-gray-300 leading-relaxed"
          >
            {data.sections.personal.content}
          </p>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  /* Hover effects for the cards */
  #about-journey:hover,
  #about-experience:hover,
  #about-workstyle:hover,
  #about-goals:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 40px -10px rgba(139, 92, 246, 0.3);
  }

  #about-personal:hover {
    transform: translateY(-2px);
  }

  /* Smooth transitions */
  #about-journey,
  #about-experience,
  #about-workstyle,
  #about-goals,
  #about-personal {
    transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
  }
</style>