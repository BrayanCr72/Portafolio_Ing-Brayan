---
import { heroData } from "../data/heroData";

interface Props {
  lang?: "es" | "en";
}

const { lang = "en" } = Astro.props;
const data = heroData[lang];
const Url: string = import.meta.env.BUCKET_URL || '';
const ingenieroImg: string = "/Image/ingeniero.png?token=eyJraWQiOiJzdG9yYWdlLXVybC1zaWduaW5nLWtleV8xZGUzNTlkZi05MWEzLTQzMzMtOWVhZS00YjExZDE4YTZmYjAiLCJhbGciOiJIUzI1NiJ9.eyJ1cmwiOiJJbWcvSW1hZ2UvaW5nZW5pZXJvLnBuZyIsImlhdCI6MTc3NTQ1NjY3OCwiZXhwIjoyMDkwODE2Njc4fQ.B8i-CabMgex-LgokhWT1pY7AwMpByJbpI58aeD7Y4UY";
---

<section
  id="hero"
  class="mmin-h-screen  from-slate-900 to-slate-800 text-white py-20 relative overflow-hidde"
>
  <!-- <div id="hero-bg-overlay" class="absolute inset-0 opacity-0">
    <div class="absolute top-20 left-10 w-72 h-72 bg-purple-500 rounded-full mix-blend-multiply filter blur-xl animate-blob"></div>
    <div class="absolute top-40 right-10 w-72 h-72 bg-yellow-500 rounded-full mix-blend-multiply filter blur-xl animate-blob animation-delay-2000"></div>
    <div class="absolute -bottom-8 left-20 w-72 h-72 bg-pink-500 rounded-full mix-blend-multiply filter blur-xl animate-blob animation-delay-4000"></div>
  </div> -->

  <div class="container mx-auto px-6 py-20 relative z-10">
    <div id="hero-header" class="mb-16 pt-10 opacity-0">
      <div class="flex flex-col md:flex-row items-center justify-center gap-12 max-w-7xl mx-auto">

        <div id="hero-image-container" class="w-64 h-64 md:w-80 md:h-80 flex-shrink-0 pointer-events-none opacity-0">
          <img
            src={`${Url}${ingenieroImg}`}
            alt="Brayan Ordoñez"
            class="w-full h-full object-contain drop-shadow-2xl"
            draggable="false"
          />
        </div>

        <div class="flex-1 text-center md:text-left">
          <h1 id="hero-name" class="text-4xl md:text-6xl lg:text-7xl font-bold mb-10 leading-tight md:leading-snug lg:leading-snug bg-clip-text text-transparent bg-gradient-to-r from-purple-400 via-pink-400 to-yellow-400 opacity-0">
            {data.name}
          </h1>
          <h2 id="hero-title" class="text-xl md:text-3xl lg:text-4xl font-semibold mb-4 text-purple-200 opacity-0">
            {data.title}
          </h2>
          <p id="hero-tagline" class="text-base md:text-lg lg:text-xl text-gray-300 leading-relaxed opacity-0">
            "{data.tagline}"
          </p>
        </div>
      </div>
    </div>

    <div id="hero-content-text" class="max-w-4xl mx-auto opacity-0">
      <div class="bg-white/5 backdrop-blur-lg rounded-2xl p-8 md:p-12 shadow-2xl border border-white/10">
        <p class="text-lg md:text-xl text-gray-200 leading-relaxed mb-6">
          {data.sections.aboutMe.content}
        </p>
        <p class="text-lg md:text-xl text-gray-200 leading-relaxed mb-6">
          {data.sections.motivation.content}
        </p>
        <p class="text-lg md:text-xl text-gray-200 leading-relaxed">
          {
            lang === "es"
              ? `Mis valores fundamentales son ${data.sections.values.items.join(", ").toLowerCase()}.`
              : `My core values are ${data.sections.values.items.join(", ").toLowerCase()}.`
          }
        </p>
      </div>
    </div>
  </div>
</section>

<style>
  @keyframes blob {
    0% { transform: translate(0px, 0px) scale(1); }
    33% { transform: translate(30px, -50px) scale(1.1); }
    66% { transform: translate(-20px, 20px) scale(0.9); }
    100% { transform: translate(0px, 0px) scale(1); }
  }
  .animate-blob { animation: blob 7s infinite; }
  .animation-delay-2000 { animation-delay: 2s; }
  .animation-delay-4000 { animation-delay: 4s; }
</style>