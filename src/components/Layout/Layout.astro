---
import Navbar from './Navbar.astro';
import Footer from './Footer.astro';
import { getLanguageFromUrl, type Language } from '../../utils/language';
import '../../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  lang?: Language;
}
const { 
  title = 'Brayan Ordoñez - Full Stack Developer', 
  description = 'Portafolio de Brayan Ordoñez, Ingeniero en Sistemas y Desarrollador Full Stack',
  lang: langProp
} = Astro.props;

// Obtener idioma desde la URL
const lang: Language = langProp ?? getLanguageFromUrl(Astro.url);
---

<!DOCTYPE html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  
  <body class="bg-slate-900">
    <Navbar currentLang={lang} />
    
    <main id="main-content" data-gsap="main-content">
      <slot lang={lang} />
    </main>
    
    <Footer lang={lang} />
  </body>
</html>