<script>
  // Aplicar idioma al footer al cargar
  function applyFooterLang(lang: string) {
    const footerEs = document.getElementById('footer-es');
    const footerEn = document.getElementById('footer-en');
    if (footerEs && footerEn) {
      footerEs.style.display = lang === 'es' ? 'block' : 'none';
      footerEn.style.display = lang === 'en' ? 'block' : 'none';
    }
  }

  const savedLang = (() => {
    const params = new URLSearchParams(window.location.search);
    const urlLang = params.get('lang');
    if (urlLang === 'es' || urlLang === 'en') return urlLang;
    return localStorage.getItem('lang') || 'en';
  })();

  applyFooterLang(savedLang);
</script>